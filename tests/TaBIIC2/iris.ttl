:Id a owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

:SepalLengthCm a owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

:Species a owl:ObjectProperty .

:SepalWidthCm a owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

:PetalWidthCm a owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

:PetalLengthCm a owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

:MediumWidthPetalris a owl:Class ;
    rdfs:label "MediumWidthPetalris" ;
    rdfs:subClassOf :Iris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalWidthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:minInclusive 1.0 ] [ xsd:maxExclusive 1.16 ] ) ] ] ) ] .

:MediumLongPetalIris a owl:Class ;
    rdfs:label "MediumLongPetalIris" ;
    rdfs:subClassOf :Iris,
        :MerdiumLengthPetalIris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalLengthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:minInclusive 3.33 ] [ xsd:maxExclusive 4.1 ] ) ] ] ) ] .

:MediumShortPetalIris a owl:Class ;
    rdfs:label "MediumShortPetalIris" ;
    rdfs:subClassOf :Iris,
        :MerdiumLengthPetalIris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalLengthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:minInclusive 1.7 ] [ xsd:maxExclusive 3.9 ] ) ] ] ) ] .

:MerdiumLengthPetalIris a owl:Class ;
    rdfs:label "MerdiumLengthPetalIris" ;
    rdfs:subClassOf :Iris ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( :MediumShortPetalIris :MediumLongPetalIris ) ] .

:LargePetalWideSepalIris a owl:Class ;
    rdfs:label "LargePetalWideSepalIris" ;
    rdfs:subClassOf :LargePetalIris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :LargePetalIris [ a owl:Restriction ;
                        owl:onProperty :SepalWidthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:minInclusive 3.04 ] ) ] ] ) ] .

:SmallPetalIris a owl:Class ;
    rdfs:label "SmallPetalIris" ;
    rdfs:subClassOf :NarrowPetalIris,
        :ShortPetalIris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :ShortPetalIris :NarrowPetalIris ) ] .

:Species_Iris-setosa a owl:NamedIndividual ;
    rdfs:label "Iris-setosa" .

:Species_Iris-versicolor a owl:NamedIndividual ;
    rdfs:label "Iris-versicolor" .

:Species_Iris-virginica a owl:NamedIndividual ;
    rdfs:label "Iris-virginica" .

:NarrowPetalIris a owl:Class ;
    rdfs:label "NarrowPetalIris" ;
    rdfs:subClassOf :Iris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalWidthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:maxExclusive 1.0 ] ) ] ] ) ] .

:ShortPetalIris a owl:Class ;
    rdfs:label "ShortPetalIris" ;
    rdfs:subClassOf :Iris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalLengthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:maxExclusive 3.33 ] ) ] ] ) ] .

:LargePetalNarrowSepalIris a owl:Class ;
    rdfs:label "LargePetalNarrowSepalIris" ;
    rdfs:subClassOf :LargePetalIris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :LargePetalIris [ a owl:Restriction ;
                        owl:onProperty :SepalWidthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:maxExclusive 3.04 ] ) ] ] ) ] .

:LongPetalIris a owl:Class ;
    rdfs:label "LongPetalIris" ;
    rdfs:subClassOf :Iris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalLengthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:minInclusive 4.1 ] ) ] ] ) ] .

:LargePetalIris a owl:Class ;
    rdfs:label "LargePetalIris" ;
    rdfs:subClassOf :LongPetalIris,
        :WidePetalIris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :LongPetalIris :WidePetalIris ) ] .

:WidePetalIris a owl:Class ;
    rdfs:label "WidePetalIris" ;
    rdfs:subClassOf :Iris ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Iris [ a owl:Restriction ;
                        owl:onProperty :PetalWidthCm ;
                        owl:someValuesFrom [ a rdfs:Datatype ;
                                owl:onDatatype xsd:decimal ;
                                owl:withRestrictions ( [ xsd:minInclusive 1.16 ] ) ] ] ) ] .

:Iris a owl:Class ;
    rdfs:label "Iris" ;
    rdfs:subClassOf owl:Thing .

