@prefix :    <http://example.org/iris/schema#> .
@prefix ent: <http://example.org/iris/data/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:<http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:SepalLengthCm a owl:DatatypeProperty ;
  rdfs:range xsd:decimal .

:SepalWidthCm a owl:DatatypeProperty ;
  rdfs:range xsd:decimal .

:PetalLengthCm a owl:DatatypeProperty ;
  rdfs:range xsd:decimal .

:PetalWidthCm a owl:DatatypeProperty ;
  rdfs:range xsd:decimal .

:IrisObservation a owl:Class ;
  rdfs:subClassOf owl:Thing .

:ShortPetal a owl:Class ;
  rdfs:subClassOf :IrisObservation ;
  owl:equivalentClass [ a owl:Class ;
    owl:intersectionOf ( :IrisObservation
      [ a owl:Restriction ; owl:onProperty :PetalLengthCm ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                [ xsd:maxExclusive "2.0"^^xsd:decimal ] ) ] ] ) ] .

:MediumPetal a owl:Class ;
  rdfs:subClassOf :IrisObservation ;
  owl:equivalentClass [ a owl:Class ;
    owl:intersectionOf ( :IrisObservation
      [ a owl:Restriction ; owl:onProperty :PetalLengthCm ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ( [ xsd:minInclusive "2.0"^^xsd:decimal ]
                                [ xsd:maxExclusive "5.0"^^xsd:decimal ] ) ] ] ) ] .

:MediumNarrowPetal a owl:Class ;
  rdfs:subClassOf :MediumPetal ;
  owl:equivalentClass [ a owl:Class ;
    owl:intersectionOf ( :MediumPetal
      [ a owl:Restriction ; owl:onProperty :PetalWidthCm ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                [ xsd:maxExclusive "1.5"^^xsd:decimal ] ) ] ] ) ] .

:MediumWidePetal a owl:Class ;
  rdfs:subClassOf :MediumPetal ;
  owl:equivalentClass [ a owl:Class ;
    owl:intersectionOf ( :MediumPetal
      [ a owl:Restriction ; owl:onProperty :PetalWidthCm ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ( [ xsd:minInclusive "1.5"^^xsd:decimal ]
                                [ xsd:maxInclusive "3.0"^^xsd:decimal ] ) ] ] ) ] .

:LongPetal a owl:Class ;
  rdfs:subClassOf :IrisObservation ;
  owl:equivalentClass [ a owl:Class ;
    owl:intersectionOf ( :IrisObservation
      [ a owl:Restriction ; owl:onProperty :PetalLengthCm ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ( [ xsd:minInclusive "5.0"^^xsd:decimal ]
                                [ xsd:maxInclusive "10.0"^^xsd:decimal ] ) ] ] ) ] .

