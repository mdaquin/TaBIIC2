@prefix :    <http://example.org/cars/schema#> .
@prefix ent: <http://example.org/cars/data/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:<http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Datatype Properties
:year a owl:DatatypeProperty ; rdfs:range xsd:decimal .
:price a owl:DatatypeProperty ; rdfs:range xsd:decimal .
:mileage a owl:DatatypeProperty ; rdfs:range xsd:decimal .
:mpg a owl:DatatypeProperty ; rdfs:range xsd:decimal .
:engineSize a owl:DatatypeProperty ; rdfs:range xsd:decimal .

# Object Properties
:transmission a owl:ObjectProperty .
:fuelType a owl:ObjectProperty .

# Categorical Individuals
ent:Manual a owl:NamedIndividual .
ent:Automatic a owl:NamedIndividual .
ent:Semi-Auto a owl:NamedIndividual .
ent:Other a owl:NamedIndividual .
ent:Petrol a owl:NamedIndividual .
ent:Diesel a owl:NamedIndividual .
ent:Hybrid a owl:NamedIndividual .
ent:Electric a owl:NamedIndividual .

# Taxonomy
:Vehicle a owl:Class ; rdfs:subClassOf owl:Thing .

:BudgetVehicle a owl:Class ;
  rdfs:subClassOf :Vehicle ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf ( :Vehicle
      [ a owl:Restriction ; owl:onProperty :price ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ([ xsd:minInclusive "0.0"^^xsd:decimal ] [ xsd:maxExclusive "15000.0"^^xsd:decimal ]) ] ] ) ] .

:LuxuryVehicle a owl:Class ;
  rdfs:subClassOf :Vehicle ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf ( :Vehicle
      [ a owl:Restriction ; owl:onProperty :price ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ([ xsd:minInclusive "15000.0"^^xsd:decimal ]) ] ] ) ] .

:NewBudgetVehicle a owl:Class ;
  rdfs:subClassOf :BudgetVehicle ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf ( :BudgetVehicle
      [ a owl:Restriction ; owl:onProperty :year ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ([ xsd:minInclusive "2017.0"^^xsd:decimal ]) ] ] ) ] .

:OldBudgetVehicle a owl:Class ;
  rdfs:subClassOf :BudgetVehicle ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf ( :BudgetVehicle
      [ a owl:Restriction ; owl:onProperty :year ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ([ xsd:maxExclusive "2017.0"^^xsd:decimal ]) ] ] ) ] .

:EfficientLuxuryVehicle a owl:Class ;
  rdfs:subClassOf :LuxuryVehicle ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf ( :LuxuryVehicle
      [ a owl:Restriction ; owl:onProperty :mpg ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ([ xsd:minInclusive "55.0"^^xsd:decimal ]) ] ] ) ] .

:PerformanceLuxuryVehicle a owl:Class ;
  rdfs:subClassOf :LuxuryVehicle ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf ( :LuxuryVehicle
      [ a owl:Restriction ; owl:onProperty :mpg ;
        owl:someValuesFrom [ a rdfs:Datatype ; owl:onDatatype xsd:decimal ;
          owl:withRestrictions ([ xsd:maxExclusive "55.0"^^xsd:decimal ]) ] ] ) ] .

